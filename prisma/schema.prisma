generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  plan      String   @default("free")
  theme     String   @default("{}")
  createdAt DateTime @default(now())

  users    User[]
  courses  Course[]
  packages Package[]
}

model User {
  id        String   @id @default(cuid())
  email     String
  password  String?
  name      String?
  role      String   @default("learner")
  tenantId  String
  createdAt DateTime @default(now())

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  enrollments         Enrollment[]
  passwordResetTokens PasswordResetToken[]
  groupMembers        GroupMember[]
  ratings             CourseRating[]

  @@unique([email, tenantId])
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String?
  categories  String   @default("[]")
  imageUrl    String?
  status      String   @default("draft")
  tenantId    String
  createdAt   DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  modules     Module[]
  enrollments Enrollment[]
}

model Module {
  id       String @id @default(cuid())
  order    Int
  courseId String
  tenantId String
  type     String
  content  String @default("{}")

  course Course @relation(fields: [courseId], references: [id])
}

model Package {
  id         String @id @default(cuid())
  storageKey String
  version    String @default("1.2")
  tenantId   String

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model Enrollment {
  id        String    @id @default(cuid())
  status    String    @default("enrolled")
  userId    String
  courseId  String
  tenantId  String
  dueDate   DateTime?
  createdAt DateTime  @default(now())

  user     User       @relation(fields: [userId], references: [id])
  course   Course     @relation(fields: [courseId], references: [id])
  progress Progress[]

  @@unique([userId, courseId])
}

model Progress {
  id           String    @id @default(cuid())
  cmi          String    @default("{}")
  score        Float?
  completedAt  DateTime?
  timeSpent    Int?
  tenantId     String
  enrollmentId String    @unique

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  actorId    String?
  actorEmail String?
  targetId   String?
  targetType String?
  metadata   String   @default("{}")
  tenantId   String?
  createdAt  DateTime @default(now())
}

// ─── Groups / Cohorts ───────────────────────────────────────────────────────

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  tenantId    String
  createdAt   DateTime @default(now())

  members GroupMember[]
  courses GroupCourse[]
}

model GroupMember {
  id       String @id @default(cuid())
  groupId  String
  userId   String
  tenantId String

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model GroupCourse {
  id         String    @id @default(cuid())
  groupId    String
  courseId   String
  tenantId   String
  dueDate    DateTime?
  assignedAt DateTime  @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, courseId])
}

// ─── Course Ratings ─────────────────────────────────────────────────────────

model CourseRating {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  tenantId  String
  rating    Int      // 1–5
  comment   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
}
